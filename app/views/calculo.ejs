<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BURGCALC - Calculo</title>
  <link rel="stylesheet" href="/burgcalc.css">
</head>
<body>
  <%- include('burgcalc-topbar', { currentPage }) %>

  <main class="burgcalc-page">
    <section class="burgcalc-panel">
      <div class="burgcalc-heading-row">
        <div>
          <h1>Calculo de custo do hamburguer</h1>
          <p>Preencha os custos de producao e a margem desejada.</p>
        </div>
      </div>

      <form id="burgcalcForm" class="burgcalc-form burgcalc-grid">
        <div class="burgcalc-field">
          <label for="pao">Custo do pao</label>
          <input type="number" id="pao" name="pao" min="0" step="0.01" value="1.20" required>
        </div>

        <div class="burgcalc-field">
          <label for="carne">Custo da carne</label>
          <input type="number" id="carne" name="carne" min="0" step="0.01" value="5.50" required>
        </div>

        <div class="burgcalc-field">
          <label for="queijo">Custo do queijo</label>
          <input type="number" id="queijo" name="queijo" min="0" step="0.01" value="1.00" required>
        </div>

        <div class="burgcalc-field">
          <label for="salada">Custo da salada</label>
          <input type="number" id="salada" name="salada" min="0" step="0.01" value="0.80" required>
        </div>

        <div class="burgcalc-field">
          <label for="molho">Custo do molho</label>
          <input type="number" id="molho" name="molho" min="0" step="0.01" value="0.50" required>
        </div>

        <div class="burgcalc-field">
          <label for="embalagem">Custo da embalagem</label>
          <input type="number" id="embalagem" name="embalagem" min="0" step="0.01" value="0.70" required>
        </div>

        <div class="burgcalc-field">
          <label for="margemLucro">Margem de lucro desejada (%)</label>
          <input type="number" id="margemLucro" name="margemLucro" min="0.01" max="99.99" step="0.01" value="30" required>
        </div>

        <div class="burgcalc-actions">
          <button type="submit" id="btnCalcular" class="burgcalc-button">Calcular</button>
        </div>
      </form>

      <div id="burgcalcMensagem" class="burgcalc-message" hidden></div>

      <section class="burgcalc-results" aria-label="Resultado do calculo">
        <div>
          <span>Custo total</span>
          <strong id="custoTotal">-</strong>
        </div>
        <div>
          <span>Preco de venda sugerido</span>
          <strong id="precoVenda">-</strong>
        </div>
        <div>
          <span>Lucro estimado</span>
          <strong id="lucroEstimado">-</strong>
        </div>
      </section>
    </section>
  </main>

  <script>
    const form = document.getElementById('burgcalcForm');
    const mensagem = document.getElementById('burgcalcMensagem');

    function valorCampo(nome) {
      return Number(document.getElementById(nome).value);
    }

    function dinheiro(valor) {
      return `R$ ${Number(valor).toFixed(2).replace('.', ',')}`;
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      mensagem.hidden = true;

      const payload = {
        pao: valorCampo('pao'),
        carne: valorCampo('carne'),
        queijo: valorCampo('queijo'),
        salada: valorCampo('salada'),
        molho: valorCampo('molho'),
        embalagem: valorCampo('embalagem'),
        margemLucro: valorCampo('margemLucro'),
      };

      try {
        const resposta = await fetch('/burgcalc/calcular', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const json = await resposta.json();

        if (!json.success) {
          throw new Error(json.message || 'Valores invalidos');
        }

        document.getElementById('custoTotal').textContent = dinheiro(json.custoTotal);
        document.getElementById('precoVenda').textContent = dinheiro(json.precoVenda);
        document.getElementById('lucroEstimado').textContent = dinheiro(json.lucroEstimado);
      } catch (erro) {
        mensagem.textContent = erro.message;
        mensagem.hidden = false;
      }
    });
  </script>
</body>
</html>
